
<div class="container">
    <div class="col-sm-6">
        <img src="/images/product.jpg" alt="">
    </div>

    <div class="col-sm-6">
        <h1 class="title">Learn to cook cutting edge food</h1>
        <!-- ★ ここから EJS のループ部分を追加 -->
