<%# 既存のユーザー属性値を編集フォームに適用する %>
<div class="data-form">
    <form method="POST" action="<%= `/subscribers/${subscriber._id}/update?_method=PUT` %>">
        <h2>Edit subscriber</h2>
        <label for="inputName">Name</label>
        <input type="text" name="name" id="inputName"
               value="<%= subscriber.name %>" placeholder="Name" autofocus><br>
        <label for="inputEmail">Email</label>
        <input type="email" name="email" id="inputEmail"
               value="<%= subscriber.email %>" placeholder="Email address" required><br>
        <label for="inputMembershipNumber">Membership Number</label>
        <input type="text" name="membershipNumber" id="inputMembershipNumber" pattern="^\d{5}$"
               value="<%= subscriber.membershipNumber %>"  placeholder="Membership Number" required><br>
        <button type="submit">Update</button>
    </form>
</div>