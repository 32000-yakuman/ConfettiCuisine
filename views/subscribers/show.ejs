<h1><%= subscriber.name %></h1>

<table class="table">
    <tr>
        <td>Name</td>
        <td><%= subscriber.name %></td>
    </tr>
    <tr>
        <td>Email</td>
        <td><%= subscriber.email %></td>
    </tr>
    <tr>
        <td>Membership Number</td>
        <td><%= subscriber.membershipNumber %></td>
    </tr>
</table>

<p>This subscriber has <%= subscriber.courses.length %> associated course(s)</p>

<div>
    <a class="button" href="/subscribers">View All Subscribers</a>
</div>
<div>
    <a class="button" href="<%= `/subscribers/${subscriber._id}/edit` %>">
        Edit Subscriber Details
    </a>
</div>
<div>
    <a class="button" href="<%= `/subscribers/${subscriber._id}/delete?_method=DELETE` %>"
     onclick="return confirm('Are you sure you want to delete this subscriber?')">
     Delete</a>
</div>