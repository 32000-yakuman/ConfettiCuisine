<link rel="stylesheet" href="/styles.css">

<h1><%= user.fullName %></h1>

<table class="table">
    <tr>
        <td>Name</td>
        <td><%= user.fullName %></td>
    </tr>
    <tr>
        <td>Email</td>
        <td><%= user.email %></td>
    </tr>
    <tr>
        <td>Membership Number</td>
        <td><%= user.membershipNumber %></td>
    </tr>
</table>

<% if (user.subscribedAccount) { %>
    <h4 class="center"> This user has a 
    <a class="button" href="<%=`/subscribers/${user.subscribedAccount}` %>">
        subscribed account. </a>
    </h4>
<% } %>



<div>
    <a class="button" href="/users">View All Users</a>
</div>
<div>
    <a class="button" href="<%= `/users/${user._id}/edit` %>">
        Edit User Details
    </a>
</div>
<form action="/users/<%= user._id %>/delete?_method=DELETE" method="POST" style="display:inline;">
    <button class="button" onclick="return confirm('Are you sure you want to delete this user?')">
        Delete
    </button>
</form>

