<h1 class="center">
    <%= course.title %>
</h1>

<table class="table">
    <tr>
        <td>Title</td>
        <td><%= course.title %></td>
    </tr>
    <tr>
        <td>Description</td>
        <td><%= course.description %></td>
    </tr>
    <tr>
        <td>Items</td>
        <td><%= course.items %></td>
    </tr>
    <tr>
        <td>Fee</td>
        <td><%= course.fee %></td>
    </tr>
    <tr>
        <td>Course Code</td>
        <td><%= course.membershipNumber %></td>
    </tr>
</table>

<div>
    <a class="button" href="/courses">View All users</a>
</div>
<div>
    <a class="button" href="<%= `/courses/${course._id}/edit` %>">
        Edit Course Details
    </a>
</div>
<div>
    <a class="button" href="<%= `/courses/${course._id}/delete?_method=DELETE` %>"
     onclick="return confirm('Are you sure you want to delete this course?')">
     Delete</a>
</div>